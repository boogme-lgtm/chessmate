/**
 * BooGMe mark — circle (top-left) + lightning bolt (center) + triangle (bottom-right)
 * Reconstructed as SVG from the reference raster so it can be tinted and scaled crisply.
 */
function BgMark({ size = 64, color = "#8B4513", title = "BooGMe" }) {
  return (
    <svg
      width={size}
      height={size}
      viewBox="0 0 200 200"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-label={title}
      role="img"
    >
      {/* Circle */}
      <circle cx="66" cy="60" r="32" fill={color} />
      {/* Lightning bolt (right-ish) */}
      <path
        d="M112 28 L152 28 L126 82 L158 82 L96 170 L116 104 L88 104 Z"
        fill={color}
      />
      {/* Triangle (bottom) */}
      <path d="M34 172 L166 172 L100 108 Z" fill={color} />
    </svg>
  );
}

function BgLogo({ size = 56, color = "#8B4513", showWordmark = true, stacked = false, wordmarkColor }) {
  const wm = wordmarkColor || color;
  if (stacked) {
    return (
      <div style={{ display: "inline-flex", flexDirection: "column", alignItems: "center", gap: 10 }}>
        <BgMark size={size} color={color} />
        {showWordmark && (
          <span style={{
            fontFamily: "Inter, Helvetica Neue, sans-serif",
            fontWeight: 300,
            letterSpacing: "0.28em",
            fontSize: size * 0.32,
            color: wm,
          }}>BOOGME</span>
        )}
      </div>
    );
  }
  return (
    <div style={{ display: "inline-flex", alignItems: "center", gap: size * 0.25 }}>
      <BgMark size={size} color={color} />
      {showWordmark && (
        <span style={{
          fontFamily: "Inter, Helvetica Neue, sans-serif",
          fontWeight: 300,
          letterSpacing: "0.24em",
          fontSize: size * 0.42,
          color: wm,
        }}>BOOGME</span>
      )}
    </div>
  );
}

/** Minimal chess board glyph — functional placeholder, not a full SVG drawing */
function BgChessGlyph({ size = 80, accent = "#8B4513", dark = "#2C2C2C" }) {
  const cells = [];
  for (let r = 0; r < 4; r++) {
    for (let c = 0; c < 4; c++) {
      const fill = (r + c) % 2 === 0 ? "#F5F1E4" : dark;
      cells.push(
        <rect key={`${r}-${c}`} x={c * (size / 4)} y={r * (size / 4)} width={size / 4} height={size / 4} fill={fill} />
      );
    }
  }
  return (
    <svg width={size} height={size} viewBox={`0 0 ${size} ${size}`}>
      {cells}
      <circle cx={size * 0.72} cy={size * 0.28} r={size * 0.1} fill={accent} />
    </svg>
  );
}

