        {loop.map((t, i) => (
          <span key={i}><span className="dot"/> {t}</span>
        ))}
      </div>
    </div>
  );
}

function Gauge({ value = 94, size = 120 }) {
  const r = (size - 12) / 2;
  const c = 2 * Math.PI * r;
  const offset = c - (value / 100) * c;
  return (
    <svg className="gauge-ring" width={size} height={size} viewBox={`0 0 ${size} ${size}`}>
      <circle className="track" cx={size/2} cy={size/2} r={r} fill="none" strokeWidth="6"/>
      <circle className="fill" cx={size/2} cy={size/2} r={r} fill="none" strokeWidth="6"
        strokeDasharray={c} strokeDashoffset={offset}/>
    </svg>
  );
}

